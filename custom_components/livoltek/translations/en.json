{
  "config": {
    "step": {
      "user": {
        "title": "Connect Livoltek",
        "description": "Enter your Livoltek API credentials. The Security ID and Security Key are found under My Profile → Security ID — paste the Security Key exactly as shown, including the trailing \\r\\n characters. The User Token is generated from My Profile → Generate Token.",
        "data": {
          "secuid": "Security ID",
          "api_key": "Security Key",
          "user_token": "User Token"
        }
      },
      "select_site": {
        "title": "Select site",
        "description": "Choose which Livoltek site to add to Home Assistant.",
        "data": {
          "site_id": "Site"
        }
      },
      "reauth_confirm": {
        "title": "Re-authenticate Livoltek",
        "description": "Your Livoltek credentials have expired or been rejected. Please re-enter them.",
        "data": {
          "secuid": "Security ID",
          "api_key": "Security Key",
          "user_token": "User Token"
        }
      }
    },
    "error": {
      "invalid_auth": "The Security ID or Security Key was rejected. Double-check the values copied from the Livoltek portal and paste the key exactly as shown, including the trailing \\r\\n characters.",
      "cannot_connect": "Unable to reach the Livoltek portal. The integration runs from your home network — check that port 8081 is reachable from this Home Assistant instance.",
      "no_sites_found": "No sites are visible to this account.",
      "unknown": "An unexpected error occurred. Check the Home Assistant logs for details."
    },
    "abort": {
      "already_configured": "Livoltek is already configured.",
      "reauth_successful": "Livoltek credentials updated successfully.",
      "no_devices_found": "The selected site has no inverter devices registered against it.",
      "cannot_connect": "The Livoltek API returned an unexpected response while resolving the site or its devices. Check the Home Assistant logs for details."
    }
